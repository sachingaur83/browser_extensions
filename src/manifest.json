{
  "manifest_version": 3,
  "name": "Hide YouTube Shorts",
  "version": "1.0",
  "description": "Removes YouTube Shorts from the site.",
  "permissions": ["activeTab", "scripting","declarativeNetRequest", "declarativeNetRequestFeedback", "storage"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*",
    "*://youtu.be/*",
    "*://m.youtube.com/*",
    "*://www.tiktok.com/*",
    "*://tiktok.com/*",
    "*://open.spotify.com/*",
    "*://www.instagram.com/*",
    "*://instagram.com/*",
    "*://www.facebook.com/*",
    "*://facebook.com/*",
    "*://www.reddit.com/*",
    "*://reddit.com/*",
    "*://www.twitter.com/*",
    "*://twitter.com/*",
    "*://x.com/*",
    "*://www.roblox.com/*",
    "*://roblox.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": ["content.bundle.js"]
    }
  ],
  "background": {
    "service_worker": "background.bundle.js",
    "type": "module"
  },
  "options_page": "options.html"
}
